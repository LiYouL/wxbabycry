<view class="container">
  <view class="profile-header">
    <view class="avatar">👶</view>
    <text class="nickname">{{babyInfo.nickname || '未设置宝宝'}}</text>
    <view class="greeting" wx:if="{{greeting}}">
      <text>{{greeting}}</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goEditBaby">📝 宝宝信息设置</view>
    <view class="menu-item" bindtap="goNoise">🎵 白噪音</view>
    <view class="menu-item" bindtap="goRecords">🍼 成长记录</view>
    <view class="menu-item" bindtap="goGrowth">📊 成长分析</view>
    <view class="menu-item" bindtap="goGuide">📘 使用指南</view>
    <view class="menu-item" bindtap="goFeedback">📮 意见反馈</view>
    <view class="menu-item" bindtap="shareApp">📤 分享小程序</view>
  </view>
</view>
