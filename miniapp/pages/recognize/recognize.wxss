.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
  min-height: 100vh;
}

.header {
  margin-bottom: 20rpx;
}

.baby-name {
  font-size: 28rpx;
  color: #999;
}

.cry-animation {
  margin: 40rpx 0;
}

.cry-img {
  font-size: 180rpx;
  text-align: center;
  line-height: 240rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: #fce4ec;
}

.shake {
  animation: shake 0.5s infinite;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-4rpx); }
  75% { transform: translateX(4rpx); }
}

.record-section {
  text-align: center;
  margin-top: 40rpx;
}

.status-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.status-text.recording {
  color: #FF6B6B;
}

.waveform {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  height: 60rpx;
  gap: 6rpx;
  margin-bottom: 30rpx;
}

.wave-bar {
  width: 8rpx;
  background: linear-gradient(to top, #FFB6C1, #FF69B4);
  border-radius: 4rpx;
  animation: waveHeight 0.8s ease-in-out infinite alternate;
}

@keyframes waveHeight {
  0% { height: 10rpx; }
  100% { height: 50rpx; }
}

.record-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin: 0 auto;
  box-shadow: 0 8rpx 24rpx rgba(255,105,180,0.3);
}

.record-btn.recording {
  background: linear-gradient(135deg, #FF6B6B, #FF4444);
  animation: pulse 1.2s infinite;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255,68,68,0.4); }
  50% { box-shadow: 0 0 0 20rpx rgba(255,68,68,0); }
}

.hint {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 20rpx;
}

.analyze-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(255, 248, 250, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
}

.analyze-panel {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 42rpx 36rpx;
  text-align: center;
  box-shadow: 0 12rpx 40rpx rgba(255, 105, 180, 0.18);
}

.analyze-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #e91e63;
  margin-bottom: 14rpx;
}

.analyze-subtitle {
  font-size: 26rpx;
  color: #777;
  margin-bottom: 28rpx;
}

.progress-track {
  height: 18rpx;
  background: #f7dce6;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffb6c1, #ff69b4);
  border-radius: 999rpx;
  transition: width 0.25s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}
