.container {
  padding: 30rpx;
  min-height: 100vh;
}

.page-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 30rpx;
}

.now-playing {
  background: #fff;
  color: #FF69B4;
  font-size: 26rpx;
  text-align: center;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.noise-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.noise-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.noise-card.playing {
  border-color: #FFB6C1;
  box-shadow: 0 4rpx 24rpx rgba(255,105,180,0.15);
  background: #FFF5F7;
}

.card-icon {
  font-size: 64rpx;
  line-height: 80rpx;
  margin-bottom: 10rpx;
}

.icon-pulse {
  animation: softPulse 1.5s ease-in-out infinite;
}

@keyframes softPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

.card-name {
  font-size: 24rpx;
  color: #555;
  text-align: center;
  margin-bottom: 8rpx;
}

.card-status {
  min-height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-hint {
  font-size: 22rpx;
  color: #aaa;
}

.playing-label {
  font-size: 22rpx;
  color: #FF69B4;
  font-weight: 600;
}

@keyframes dotPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.6); }
}

.footer-hint {
  text-align: center;
  color: #ccc;
  font-size: 26rpx;
  padding-top: 80rpx;
}
