<view class="container">
  <view class="page-desc">点击卡片播放白噪音，帮助宝宝放松入睡</view>

  <view class="noise-grid">
    <view class="noise-card {{activeId === item.id && isPlaying ? 'playing' : ''}}"
          wx:for="{{items}}" wx:key="id"
          data-id="{{item.id}}" bindtap="togglePlay">
      <view class="card-icon {{activeId === item.id && isPlaying ? 'icon-pulse' : ''}}">
        {{item.icon}}
      </view>
      <text class="card-name">{{item.name}}</text>
      <view class="card-status">
        <text wx:if="{{activeId === item.id && isPlaying}}" class="playing-dot"></text>
        <text wx:else class="play-hint">▶</text>
      </view>
    </view>
  </view>

  <view class="footer-hint" wx:if="{{items.length === 0}}">暂无可用白噪音</view>
</view>
