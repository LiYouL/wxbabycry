.container {
  padding: 30rpx;
}

.greeting {
  background: linear-gradient(135deg, #FFB6C1, #FF69B4);
  color: #fff;
  padding: 40rpx 30rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  text-align: center;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.grid-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 50rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.grid-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}
